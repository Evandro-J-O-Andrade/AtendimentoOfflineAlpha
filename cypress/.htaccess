# 1. CORREÇÃO DE MIME TYPE (Se necessário)
AddType application/javascript .js 

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase / 

  # 2. EXCLUSÃO CRÍTICA DA API: 
  # Se a URL começar com /api/, PARE o processamento do RewriteEngine e deixe o Apache lidar com o Alias.
  RewriteRule ^api/.* - [L] 

  # 3. Se o arquivo ou diretório existe, não faça nada.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  
  # 4. Fallback do React: Redireciona o restante para index.html
  RewriteRule . /index.html [L]
</IfModule>