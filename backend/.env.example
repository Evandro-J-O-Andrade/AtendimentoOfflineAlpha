# ===========================================================
# Arquivo: .env.example
# Copie para .env e preencha com seus valores reais
# NUNCA faça commit do .env com dados sensíveis!
# ===========================================================

# ========== SERVER ==========
NODE_ENV=development
PORT=3000

# ========== MYSQL DATABASE ==========
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=sua_senha_aqui
DB_DATABASE=pronto_atendimento
DB_CONNECTION_LIMIT=10
DB_WAIT_FOR_CONNECTIONS=true
DB_QUEUE_LIMIT=0
DB_ENABLE_KEEP_ALIVE=true
DB_KEEP_ALIVE_INITIAL_DELAY_MS=0

# ========== JWT ==========
JWT_SECRET=sua_chave_secreta_super_segura_aqui_mudando_em_producao
JWT_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
JWT_REFRESH_SECRET=sua_chave_refresh_diferente_aqui

# ========== BCRYPT ==========
BCRYPT_ROUNDS=10

# ========== CORS ==========
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# ========== LOGGING ==========
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# ========== RATE LIMITING (opcional) ==========
RATE_LIMIT_WINDOWMS=900000
RATE_LIMIT_MAXREQUESTS=100

# ========== ARQUIVO UPLOAD (opcional) ==========
UPLOAD_DIR=uploads/
MAX_FILE_SIZE=10485760

# ========== EMAIL NOTIFICAÇÕES (opcional) ==========
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@pronto-atendimento.local

# ========== ACESSO SENHA PADRÃO (DEV ONLY) ==========
DEFAULT_ADMIN_PASSWORD=Admin@123456
